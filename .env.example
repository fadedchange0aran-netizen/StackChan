# VPS Bridge Python Configuration Template
# Copy this file to ".env" and replace placeholder values before starting vps_bridge.py.

# --- Required ---

# OpenAI-compatible chat/completions gateway
STACKCHAN_GATEWAY_URL=https://your-gateway.example.com/v1/chat/completions
STACKCHAN_GATEWAY_KEY=your_gateway_api_key_here
STACKCHAN_MODEL_NAME=your_chat_model_name_here

# Groq API key for STT and vision
STACKCHAN_GROQ_API_KEY=your_groq_api_key_here

# Main voice WebSocket auth token
STACKCHAN_VOICE_WS_TOKEN=YOUR_VOICE_TOKEN_HERE

# Optional separate token for robot control channel and HTTP endpoints like /capture and /vision/explain
# If you do not need a separate token, keep this equal to STACKCHAN_VOICE_WS_TOKEN.
STACKCHAN_CONTROL_WS_TOKEN=YOUR_CONTROL_TOKEN_HERE

# --- Common Optional ---

# Default robot id (MAC). If omitted, MCP tools must pass robot_id explicitly.
STACKCHAN_DEFAULT_ROBOT_ID=

# If you want to keep the original local identifier behavior, you can set this to hi-stack-chan.
STACKCHAN_DEVICE_ID=your_device_id_here

# Voice / vision selection
STACKCHAN_VOICE_NAME=zh-CN-YunxiNeural
STACKCHAN_VISION_MODEL_NAME=meta-llama/llama-4-scout-17b-16e-instruct

# Service listen addresses
STACKCHAN_APP_HOST=0.0.0.0
STACKCHAN_APP_PORT=3000
STACKCHAN_CONTROL_WS_HOST=0.0.0.0
STACKCHAN_CONTROL_WS_PORT=8765

# TTS streaming tuning for control-channel fallback
STACKCHAN_TTS_FRAME_MS=60
STACKCHAN_TTS_OPUS_BITRATE=48k
STACKCHAN_FFMPEG_PATH=ffmpeg

# Photo storage directory on the VPS / local server
STACKCHAN_PHOTO_DIR=photos

# Optional API endpoint overrides
STACKCHAN_STT_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
STACKCHAN_VISION_API_URL=https://api.groq.com/openai/v1/chat/completions
