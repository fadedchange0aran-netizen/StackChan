# VPS Bridge Python Configuration Template
# Copy this to ".env" and fill in your values.

# Groq API Key
STACKCHAN_GROQ_API_KEY=your_groq_api_key_here

# Voice WebSocket Token
STACKCHAN_VOICE_WS_TOKEN=YOUR_TOKEN_HERE

# Custom Gateway URL
STACKCHAN_GATEWAY_URL=https://your-gateway.example.com/v1

# Device Configuration
# If you want to keep the original official default device identifier locally,
# you can set this to hi-stack-chan in your own .env file.
STACKCHAN_DEVICE_ID=your_device_id_here
